PORT=3001
NODE_ENV=development

# Use sqlite for local dev (no Docker needed). Set DB_TYPE=postgres for production.
DB_TYPE=sqlite
DB_PATH=marketplace.db

# PostgreSQL (when using docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=marketplace
DB_PASSWORD=marketplace_secret
DB_DATABASE=marketplace

JWT_SECRET=marketplace_jwt_super_secret_key_change_in_production_2024
JWT_EXPIRES_IN=7d

UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

FRONTEND_URL=http://localhost:3000

# Production: comma-separated Vercel URLs (frontend + admin)
# ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-admin.vercel.app

# Neon PostgreSQL connection string (alternative to DB_HOST/DB_PORT/...)
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
